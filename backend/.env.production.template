# ═════════════════════════════════════════════════════════════════════════════
# SELLSERA BACKEND — PRODUCTION ENVIRONMENT TEMPLATE
# ═════════════════════════════════════════════════════════════════════════════
# 
# SETUP: Copy this to `.env` and fill in your production values
# 
# Quick Start:
#   1. cp .env.production.template .env
#   2. Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   3. Replace all YOUR_*_HERE placeholders with your actual credentials
# 
# ═════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3001
APP_NAME=Sellsera

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://sellseraApp:YOUR_DB_PASSWORD_HERE@127.0.0.1:27017/sellsera_production?authSource=sellsera_production

# ─────────────────────────────────────────────────────────────────────────────
# JWT SECRETS (Generate with crypto.randomBytes)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_64_CHAR_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=YOUR_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND URLS
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_URL=https://api.sellsera.com
MARKETING_URL=https://sellsera.com
CUSTOMER_FRONTEND_URL=https://seller.sellsera.com
CUSTOMER_CENTER_URL=https://seller.sellsera.com
ADMIN_CENTER_URL=https://me.sellsera.com
CORS_ORIGIN=https://sellsera.com,https://www.sellsera.com,https://seller.sellsera.com,https://me.sellsera.com

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE PAYMENT
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_MODE=live

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SendGrid recommended)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
EMAIL_FROM=noreply@sellsera.com
EMAIL_FROM_NAME=Sellsera

# ─────────────────────────────────────────────────────────────────────────────
# FILE UPLOADS
# ─────────────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/home/ubuntu/apps/sellsera/backend/uploads
MAX_FILE_SIZE=10485760

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12
SESSION_SECRET=YOUR_64_CHAR_RANDOM_STRING_HERE
SESSION_MAX_AGE=86400000

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=/home/ubuntu/apps/sellsera/backend/logs/app.log
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ─────────────────────────────────────────────────────────────────────────────
# ETSY API (For Sellsera features)
# ─────────────────────────────────────────────────────────────────────────────
ETSY_API_KEY=YOUR_ETSY_API_KEY
ETSY_API_SECRET=YOUR_ETSY_API_SECRET
ETSY_REDIRECT_URI=https://seller.sellsera.com/oauth/etsy/callback

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_STRIPE=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_TWO_FACTOR_AUTH=true
ENABLE_API_RATE_LIMITING=true

# ─────────────────────────────────────────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@sellsera.com
SUPER_ADMIN_KEY=YOUR_RANDOM_ADMIN_KEY_HERE

DEBUG=false
VERBOSE_LOGGING=false
ENABLE_API_DOCS=false
